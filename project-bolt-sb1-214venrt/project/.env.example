# Copy secrets to the repository-root `.env.local`.
# Runtime mode is injected by `npm run local:mock` / `npm run local:test`;
# do not add PAYMENT_MODE to this file.

# Razorpay (server secret never exposed to the browser)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# HMAC secret for short-lived download / payment verification tokens
# Generate: openssl rand -base64 32
DOWNLOAD_TOKEN_SECRET=

# -----------------------------------------------------------------------------
# Payment rate limiting (production — set in Vercel Project Env Vars)
# -----------------------------------------------------------------------------
PAYMENT_RATE_LIMIT_MAX=10
PAYMENT_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# Vercel WAF / Firewall (configure in Dashboard → Security → Firewall)
# Not runtime secrets — checklist keys for operations.
# -----------------------------------------------------------------------------
# VERCEL_WAF_ENABLED=true
# VERCEL_FIREWALL_RATE_LIMIT_RULE=path:/api/payments method:POST limit:10/60s
# VERCEL_FIREWALL_BOT_MANAGEMENT=challenge
