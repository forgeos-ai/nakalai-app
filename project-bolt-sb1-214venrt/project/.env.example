# Supabase (Path B — secure lead capture)
# Copy this file to `.env` in the project root and fill in your project values:
#   cp .env.example .env
#
# Until real keys are set, lead capture automatically falls back to localStorage
# so local `npm run dev` stays fully interactive (zero infrastructure cost).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Vercel Edge rate limiting (production — set in Vercel Project Env Vars)
# Applied by middleware.ts to POST/PUT/PATCH on /api/leads* (and profile paths)
# -----------------------------------------------------------------------------
LEAD_RATE_LIMIT_MAX=5
LEAD_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# Vercel WAF / Firewall (configure in Dashboard → Security → Firewall)
# Not runtime secrets — checklist keys for ops. See docs/vercel-edge-security.md
# -----------------------------------------------------------------------------
# VERCEL_WAF_ENABLED=true
# VERCEL_FIREWALL_RATE_LIMIT_RULE=path:/api/leads method:POST limit:10/60s
# VERCEL_FIREWALL_BOT_MANAGEMENT=challenge
